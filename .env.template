# ─── SERVER ───────────────────────────────────────────────
PORT=3001

# ─── DATABASE ─────────────────────────────────────────────
# Local dev: mongodb://mongo-user:123456@localhost:27017
# Production (Atlas): mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net
MONGO_URL=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/?appName=Cluster0
MONGO_DB_NAME=iceplay-dev

# ─── API ──────────────────────────────────────────────────
# Local dev: http://localhost:3001
# Production: https://yourapp.up.railway.app
API_URL=http://localhost:3001/api
WEB_SERVICE_URL=http://localhost:3001

# ─── CORS ─────────────────────────────────────────────────
# The frontend URL that is allowed to call this API
# Local dev: http://localhost:4200
# Production: https://your-frontend.com  (or * to allow all)
CORS_ORIGIN=http://localhost:4200

# ─── JWT ──────────────────────────────────────────────────
# Use a long random string in production — never share it
JWT_SECRET=SEED
JWT_TOKEN=CHANGE_THIS_TO_A_RANDOM_VALUE

# ─── CLOUDFLARE R2 ────────────────────────────────────────────────
R2_ACCOUNT_ID=Noneass
R2_ACCESS_KEY_ID=Noneasa
R2_SECRET_ACCESS_KEY=Noneas
R2_BUCKET_NAME=Noneas

# Max file size in MB
MAX_FILE_SIZE_MB=50

# ─── EMAIL ────────────────────────────────────────────────
# Set SEND_EMAIL=false in dev to skip real email sending
# Set SEND_EMAIL=true in production with valid Gmail credentials
SEND_EMAIL=false
MAILER_SERVICE=gmail
MAILER_EMAIL=your-gmail@gmail.com
# Gmail App Password (NOT your real password) — generated at myaccount.google.com
MAILER_SECRET_KEY=asdasd
